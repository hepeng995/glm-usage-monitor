{
  "name": "zhipu-usage-monitor",
  "displayName": "智谱用量监控",
  "description": "在VSCode状态栏实时监控智谱AI（BigModel.cn）5小时Token配额使用情况",
  "version": "0.1.0",
  "publisher": "zhipu-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zhipu.refreshUsage",
        "title": "智谱: 刷新用量",
        "icon": "$(refresh)"
      },
      {
        "command": "zhipu.showDetails",
        "title": "智谱: 查看用量详情"
      }
    ],
    "configuration": {
      "title": "智谱用量监控",
      "properties": {
        "zhipu.apiKey": {
          "type": "string",
          "default": "",
          "description": "智谱AI API Key（格式: id.secret）",
          "order": 1
        },
        "zhipu.refreshInterval": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "自动刷新间隔（分钟）",
          "order": 2
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
